generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuarios {
  id_usuario             Int           @id @default(autoincrement())
  nome_usuario           String
  email_usuario          String        @unique
  senha_usuario          String
  data_nascimento_usuario DateTime?
  sessoes                SessaoTreino[]
}

model Exercicios {
  id_exercicio           Int           @id @default(autoincrement())
  nome_exercicio         String
  descricao_exercicio    String?
  grupo_muscular_exercicio String?
  sessoes                SessaoTreino[]
}

model Comentarios {
  id_comentario          Int           @id @default(autoincrement())
  texto_comentario       String?
  relatorios             Relatorios[]
}

model SessaoTreino {
  id_sessao              Int           @id @default(autoincrement())
  caminho_json_landmarks_sessao String?
  data_atual_sessao      DateTime      @default(now())
  duracao_sessao         String?
  id_usuario             Int
  id_exercicio           Int
  usuario                Usuarios      @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  exercicio              Exercicios    @relation(fields: [id_exercicio], references: [id_exercicio])
  relatorios             Relatorios[]
}

model Relatorios {
  id_relatorio           Int           @id @default(autoincrement())
  quantidade_corretas_relatorio  Float?
  quantidade_incorretas_relatorio Float?
  precisao_media_relatorio Float?
  id_sessao              Int
  id_comentario          Int?
  sessao                 SessaoTreino  @relation(fields: [id_sessao], references: [id_sessao], onDelete: Cascade)
  comentario             Comentarios?  @relation(fields: [id_comentario], references: [id_comentario])
}
